<section class="section">
  <h2 class="section-heading">Band conditions</h2>
  <p style="color:var(--muted)">Live solar-terrestrial data, fetched client-side from HamQSL — no build step needed to keep it current.</p>

  <div class="prop-grid" id="prop-stats">
    <div class="prop-stat"><div class="value" id="stat-sfi">–</div><div class="label">Solar flux</div></div>
    <div class="prop-stat"><div class="value" id="stat-a">–</div><div class="label">A-index</div></div>
    <div class="prop-stat"><div class="value" id="stat-k">–</div><div class="label">K-index</div></div>
    <div class="prop-stat"><div class="value" id="stat-sunspots">–</div><div class="label">Sunspot no.</div></div>
  </div>

  <h3 class="section-heading" style="margin-top:2rem">Band-by-band (day / night)</h3>
  <div class="table-wrap">
    <table class="qso-log" id="band-table">
      <thead><tr><th>Band</th><th>Day</th><th>Night</th></tr></thead>
      <tbody></tbody>
    </table>
  </div>

  <p class="prop-note" id="prop-updated"></p>
</section>

<script src="{{ '/js/propagation.js' | url }}"></script>
