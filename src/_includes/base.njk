<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title or site.title }} — {{ site.tagline }}</title>
  <meta name="description" content="{{ site.tagline }} · {{ site.callsign }} · {{ site.qth }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Stencil:wght@600;800&family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ '/css/style.css' | url }}">
</head>
<body>
  <header class="topbar">
    <a href="{{ '/' | url }}" class="brand">{{ site.callsign }}</a>
    <nav class="topnav">
      <a href="{{ '/' | url }}">Log book</a>
      <a href="{{ '/log/' | url }}">QSOs</a>
      <a href="{{ '/propagation/' | url }}">Propagation</a>
      <a href="{{ '/posts/' | url }}">Posts</a>
    </nav>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <span>{{ site.callsign }} · {{ site.qth }} · grid {{ site.grid }}</span>
      <span class="footer-muted">73</span>
    </div>
  </footer>
</body>
</html>
